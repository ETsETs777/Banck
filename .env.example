# Пример переменных окружения (скопируйте в .env / .env.local и заполните).
# Не коммитьте файлы с реальными секретами.

# --- API (apps/api) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/spektors
# INTERNAL_ADMIN_TOKEN=
# INTERNAL_DEV_TOKEN=
# INTERNAL_AUTH_STRICT=1
# LLM_BASE_URL=http://127.0.0.1:11434
# CHROMA_URL=
# DISABLE_OPENAPI=0
# PUBLIC_API_URL=http://localhost:8000
# RATE_LIMIT_PER_MINUTE=120

# --- web-admin BFF (сервер Next, не браузер) ---
# INTERNAL_ADMIN_TOKEN=тот же токен, что на API (для прокси /api/internal/*)
# SPEKTORS_API_URL=http://localhost:8000

# --- Фронты ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
